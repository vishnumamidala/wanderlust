<% layout("layouts/boilerplate") %>

<div class="auth-page" style="padding-top: 120px;">
  <div class="auth-card" style="max-width: 600px;">
    <h1>Your Profile</h1>
    
    <div class="profile-header" style="display: flex; align-items: center; gap: 20px; margin-bottom: 32px; padding-bottom: 24px; border-bottom: 1px solid #e5e5e5;">
      <div class="avatar-large" style="width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg, #ff385c, #ff5a7d); display: flex; align-items: center; justify-content: center; color: white; font-size: 32px; font-weight: 600;">
        <%= currentUser.username.charAt(0).toUpperCase() %>
      </div>
      <div>
        <h2 style="font-size: 24px; font-weight: 600; margin: 0 0 4px;"><%= currentUser.username %></h2>
        <p style="color: #717171; margin: 0;"><%= currentUser.email %></p>
        <p style="color: #717171; font-size: 14px; margin: 4px 0 0;">
          Member since <%= currentUser.createdAt ? new Date(currentUser.createdAt).toLocaleDateString('en-US', { month: 'long', year: 'numeric' }) : 'Recently' %>
        </p>
      </div>
    </div>
    
    <div class="profile-sections" style="display: flex; flex-direction: column; gap: 24px;">
      <div class="profile-section">
        <h3 style="font-size: 18px; font-weight: 600; margin-bottom: 16px;">Quick Actions</h3>
        <div style="display: flex; flex-direction: column; gap: 12px;">
          <a href="/users/edit-profile" class="btn btn-outline" style="width: 100%; text-align: left; padding: 16px;">
            <i class="fa-solid fa-user-pen" style="margin-right: 12px; width: 20px;"></i>
            Edit Profile
          </a>
          <a href="/users/change-password" class="btn btn-outline" style="width: 100%; text-align: left; padding: 16px;">
            <i class="fa-solid fa-lock" style="margin-right: 12px; width: 20px;"></i>
            Change Password
          </a>
          <a href="/users/my-listings" class="btn btn-outline" style="width: 100%; text-align: left; padding: 16px;">
            <i class="fa-solid fa-house" style="margin-right: 12px; width: 20px;"></i>
            My Listings
          </a>
          <a href="/wishlists" class="btn btn-outline" style="width: 100%; text-align: left; padding: 16px;">
            <i class="fa-solid fa-heart" style="margin-right: 12px; width: 20px;"></i>
            My Wishlists
          </a>
          <a href="/bookings" class="btn btn-outline" style="width: 100%; text-align: left; padding: 16px;">
            <i class="fa-solid fa-calendar" style="margin-right: 12px; width: 20px;"></i>
            My Bookings
          </a>
        </div>
      </div>
    </div>
    
    <div style="text-align: center; margin-top: 32px;">
      <a href="/users/logout" style="color: #717171; font-size: 14px;">Log out</a>
    </div>
  </div>
</div>

