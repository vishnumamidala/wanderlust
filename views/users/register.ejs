<% layout("layouts/boilerplate") %>

<div class="auth-page">
  <div class="auth-card">
    <h1>Create your account</h1>
    
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="flash-message flash-error" style="margin-bottom: 20px;">
        <%= error %>
      </div>
    <% } %>
    
    <form action="/users/register" method="POST" class="auth-form">
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required>
      </div>
      
      <div class="form-group">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" required>
      </div>
      
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required minlength="6">
      </div>
      
      <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 8px;">Sign up</button>
    </form>
    
    <div class="auth-link">
      Already have an account? <a href="/users/login">Log in</a>
    </div>
  </div>
</div>

