<% layout("layouts/boilerplate") %>

<div class="auth-page" style="padding-top: 120px;">
  <div class="auth-card" style="max-width: 500px;">
    <h1>Change Password</h1>
    
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="flash-message flash-error" style="margin-bottom: 20px;">
        <%= error %>
      </div>
    <% } %>
    
    <form action="/users/change-password" method="POST" class="auth-form">
      <div class="form-group">
        <label for="currentPassword">Current Password</label>
        <input type="password" id="currentPassword" name="currentPassword" required>
      </div>
      
      <div class="form-group">
        <label for="newPassword">New Password</label>
        <input type="password" id="newPassword" name="newPassword" required minlength="6">
        <small style="color: #717171; font-size: 12px;">Must be at least 6 characters</small>
      </div>
      
      <div class="form-group">
        <label for="confirmPassword">Confirm New Password</label>
        <input type="password" id="confirmPassword" name="confirmPassword" required>
      </div>
      
      <div style="display: flex; gap: 12px; margin-top: 24px;">
        <button type="submit" class="btn btn-primary" style="flex: 1;">Change Password</button>
        <a href="/users/profile" class="btn btn-outline" style="flex: 1;">Cancel</a>
      </div>
    </form>
  </div>
</div>

