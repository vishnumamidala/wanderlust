<% layout("layouts/boilerplate") %>

<div class="container mt-5">
  <h1 class="mb-4">My Bookings</h1>

  <% if (bookings.length === 0) { %>
    <div class="alert alert-info">
      You have no bookings yet.
    </div>
  <% } else { %>

    <div class="row">
      <% bookings.forEach(booking => { %>
        <div class="col-md-6 mb-4">
          <div class="card shadow-sm h-100">
            
            <img 
              src="<%= booking.listing?.image?.url || booking.listing?.image %>" 
              class="card-img-top"
              style="height: 200px; object-fit: cover;"
            >

            <div class="card-body">
              <h5 class="card-title">
                <%= booking.listing?.title %>
              </h5>

              <p class="card-text">
                📍 <%= booking.listing?.location %>, <%= booking.listing?.country %>
              </p>

              <p>
                <strong>Check-in:</strong> 
                <%= booking.checkIn.toDateString() %><br>

                <strong>Check-out:</strong> 
                <%= booking.checkOut.toDateString() %><br>

                <strong>Guests:</strong> 
                <%= booking.guests %><br>

                <strong>Status:</strong> 
                <span class="badge bg-<%= booking.status === 'confirmed' ? 'success' : booking.status === 'pending' ? 'warning' : booking.status === 'completed' ? 'secondary' : 'danger' %>">
                  <%= booking.status %>
                </span><br>

                <strong>Total Paid:</strong> ₹<%= booking.totalPrice.toLocaleString("en-IN") %>
              </p>

              <% if (booking.status === "confirmed" || booking.status === "pending") { %>
                <form action="/bookings/<%= booking._id %>/cancel" method="POST">
                  <button class="btn btn-danger btn-sm">
                    Cancel Booking
                  </button>
                </form>
              <% } %>

            </div>
          </div>
        </div>
      <% }) %>
    </div>

  <% } %>
</div>
