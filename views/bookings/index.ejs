<% layout("layouts/boilerplate") %>

<div class="profile-container">
  <div class="profile-sidebar">
    <div class="profile-menu">
      <a href="/users/profile" class="profile-menu-item">
        <i class="fa-regular fa-user"></i>
        <span>Profile</span>
      </a>
      <a href="/bookings" class="profile-menu-item active">
        <i class="fa-regular fa-calendar"></i>
        <span>Trips</span>
      </a>
      <a href="/wishlists" class="profile-menu-item">
        <i class="fa-regular fa-heart"></i>
        <span>Wishlists</span>
      </a>
    </div>
  </div>
  
  <div class="profile-main">
    <h1 class="profile-title">Trips</h1>
    
    <% if (bookings.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon">
          <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" role="presentation" focusable="false" style="display: block; height: 48px; width: 48px; fill: currentColor;">
            <path d="M16 2C9 2 4 7 4 14c0 4 2 7 4 10l8 6 8-6c2-3 4-6 4-10 0-7-5-12-12-12zM16 6c3 0 6 3 6 8 0 3-1 5-2 7l-4 3-4-3c-1-2-2-4-2-7 0-5 3-8 6-8z"/>
          </svg>
        </div>
        <h2>No trips yet</h2>
        <p>Time to start packing! Search for your next adventure.</p>
        <a href="/listings" class="btn btn-primary">Start searching</a>
      </div>
    <% } else { %>
      <div class="bookings-list">
        <% bookings.forEach(booking => { %>
          <div class="booking-card">
            <div class="booking-image">
              <img src="<%= booking.listing.image.url %>" alt="<%= booking.listing.title %>">
            </div>
            <div class="booking-info">
              <h3><%= booking.listing.title %></h3>
              <p class="booking-location"><%= booking.listing.location %>, <%= booking.listing.country %></p>
              <div class="booking-dates">
                <span><%= new Date(booking.checkIn).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></span>
                <span> – </span>
                <span><%= new Date(booking.checkOut).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
              </div>
              <p class="booking-guests"><%= booking.guests %> guest<%= booking.guests > 1 ? 's' : '' %></p>
              <div class="booking-status">
                <span class="status-badge <%= booking.status %>"><%= booking.status %></span>
              </div>
            </div>
            <div class="booking-actions">
              <a href="/listings/<%= booking.listing._id %>" class="btn btn-outline">View</a>
              <% if (booking.status === 'pending' || booking.status === 'confirmed') { %>
                <form action="/bookings/<%= booking._id %>/cancel" method="POST" style="display: inline;">
                  <button type="submit" class="btn btn-outline-danger">Cancel</button>
                </form>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>

<style>
.bookings-list {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.booking-card {
  display: flex;
  gap: 24px;
  padding: 24px;
  border: 1px solid #ebebeb;
  border-radius: 12px;
  transition: box-shadow 0.2s;
}

.booking-card:hover {
  box-shadow: 0 6px 16px rgba(0,0,0,0.12);
}

.booking-image {
  width: 200px;
  height: 150px;
  border-radius: 8px;
  overflow: hidden;
  flex-shrink: 0;
}

.booking-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.booking-info {
  flex: 1;
}

.booking-info h3 {
  font-size: 18px;
  font-weight: 600;
  margin: 0 0 4px 0;
}

.booking-location {
  font-size: 14px;
  color: #717171;
  margin: 0 0 12px 0;
}

.booking-dates {
  font-size: 16px;
  font-weight: 500;
  margin-bottom: 8px;
}

.booking-guests {
  font-size: 14px;
  color: #717171;
  margin: 0 0 12px 0;
}

.status-badge {
  display: inline-block;
  padding: 4px 12px;
  border-radius: 4px;
  font-size: 12px;
  font-weight: 500;
  text-transform: capitalize;
}

.status-badge.confirmed {
  background: #d4edda;
  color: #155724;
}

.status-badge.pending {
  background: #fff3cd;
  color: #856404;
}

.status-badge.cancelled {
  background: #f8d7da;
  color: #721c24;
}

.status-badge.completed {
  background: #d1ecf1;
  color: #0c5460;
}

.booking-actions {
  display: flex;
  flex-direction: column;
  gap: 8px;
  align-items: flex-end;
}

.btn-outline {
  background: transparent;
  border: 1px solid #222;
  color: #222;
  padding: 10px 20px;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 500;
  text-decoration: none;
  cursor: pointer;
  transition: background 0.2s;
}

.btn-outline:hover {
  background: #f7f7f7;
}

.btn-outline-danger {
  background: transparent;
  border: 1px solid #ff385c;
  color: #ff385c;
  padding: 10px 20px;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
}

.btn-outline-danger:hover {
  background: #fff5f5;
}

@media (max-width: 768px) {
  .booking-card {
    flex-direction: column;
  }
  
  .booking-image {
    width: 100%;
    height: 200px;
  }
  
  .booking-actions {
    flex-direction: row;
    width: 100%;
  }
  
  .booking-actions .btn {
    flex: 1;
    text-align: center;
  }
}
</style>
