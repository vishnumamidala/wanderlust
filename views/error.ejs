<% layout("layouts/boilerplate") %>

<div style="min-height: 80vh; display: flex; align-items: center; justify-content: center; padding: 40px;">
  <div style="text-align: center; max-width: 600px;">
    <h1 style="font-size: 72px; font-weight: 700; color: #ff385c; margin: 0;"><%= statusCode %></h1>
    <h2 style="font-size: 32px; font-weight: 600; margin: 16px 0;"><%= message %></h2>
    <p style="color: #717171; margin-bottom: 32px;">
      <%= statusCode === 404 ? "The page you're looking for doesn't exist." : "Something went wrong on our end." %>
    </p>
    
    <% if (stack && process.env.NODE_ENV === 'development') { %>
      <details style="margin: 24px 0; text-align: left;">
        <summary style="cursor: pointer; color: #717171;">Show error details</summary>
        <pre style="background: #f7f7f7; padding: 16px; border-radius: 8px; overflow-x: auto; margin-top: 8px;"><%= stack %></pre>
      </details>
    <% } %>
    
    <div style="display: flex; gap: 12px; justify-content: center;">
      <a href="/listings" class="btn btn-primary">Go to Homepage</a>
      <button onclick="history.back()" class="btn btn-outline">Go Back</button>
    </div>
  </div>
</div>