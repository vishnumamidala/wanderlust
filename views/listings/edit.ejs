<% layout("layouts/boilerplate") %>

<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-lg-10 col-md-12">

      <h2 class="mb-4 fw-semibold">Edit your Listing</h2>

      <form
        method="POST"
        action="/listings/<%= listing._id %>?_method=PUT"
        class="needs-validation"
        novalidate
        enctype="multipart/form-data"
      >

        <!-- TITLE -->
        <div class="mb-3">
          <label class="form-label" for="title">Title</label>
          <input type="text" name="listing[title]" id="title" class="form-control" value="<%= listing.title %>" required>
        </div>

        <!-- DESCRIPTION -->
        <div class="mb-3">
          <label class="form-label" for="description">Description</label>
          <textarea name="listing[description]" id="description" class="form-control" rows="4" required><%= listing.description %></textarea>
        </div>

        <!-- PRIMARY IMAGE -->
        <div class="mb-3">
          <label class="form-label" for="image">Primary Image URL</label>
          <input type="text" name="listing[image][url]" id="image" class="form-control" value="<%= listing.image?.url || listing.image || '' %>" required>
        </div>

        <!-- PRICE + COUNTRY -->
        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label">Price (₹/night)</label>
            <input type="number" name="listing[price]" class="form-control" value="<%= listing.price %>" required>
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label">Country</label>
            <input type="text" name="listing[country]" class="form-control" value="<%= listing.country %>" required>
          </div>

        <!-- LOCATION -->
        <div class="mb-3">
          <label class="form-label">Location</label>
          <input type="text" name="listing[location]" class="form-control" value="<%= listing.location %>" required>
        </div>

        <!-- PROPERTY DETAILS -->
        <div class="row">
          <div class="col-md-3 mb-3">
            <label class="form-label">Bedrooms</label>
            <input type="number" name="listing[bedrooms]" class="form-control" value="<%= listing.bedrooms || 1 %>">
          </div>
          <div class="col-md-3 mb-3">
            <label class="form-label">Bathrooms</label>
            <input type="number" name="listing[bathrooms]" class="form-control" value="<%= listing.bathrooms || 1 %>">
          </div>
          <div class="col-md-3 mb-3">
            <label class="form-label">Beds</label>
            <input type="number" name="listing[beds]" class="form-control" value="<%= listing.beds || 1 %>">
          </div>
          <div class="col-md-3 mb-3">
            <label class="form-label">Max Guests</label>
            <input type="number" name="listing[guests]" class="form-control" value="<%= listing.guests || 2 %>">
          </div>

        <!-- CATEGORY -->
        <div class="mb-4">
          <label class="form-label">Category</label>
          <select name="listing[category]" class="form-select" required>
            <option value="">Select category</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat %>" <%= listing.category === cat ? 'selected' : '' %>><%= cat %></option>
            <% }) %>
          </select>
        </div>

        <!-- ACTIONS -->
        <div class="d-flex gap-3">
          <button class="btn btn-danger">Save Changes</button>
          <a href="/listings/<%= listing._id %>" class="btn btn-outline-secondary">Cancel</a>
        </div>

      </form>
    </div>
</div>
