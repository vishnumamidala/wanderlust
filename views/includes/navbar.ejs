<% if (typeof currentUser !== 'undefined' && currentUser) { %>

      <!-- ✅ Correct Stripe Connect Entry -->
      <a href="/connect" class="host-btn">
        Become a Host
      </a>

      <a href="/wishlists" class="host-btn">Wishlists</a>
      <a href="/bookings" class="host-btn">Trips</a>

      <button class="user-dropdown-btn"
              onclick="window.location.href='/users/profile'">
        <span style="font-size:14px; color:#737373;">
          <%= currentUser.username %>
        </span>
        <div class="user-avatar-small">
          <%= currentUser.username
              ? currentUser.username.charAt(0).toUpperCase()
              : 'U' %>
        </div>
      </button>

    <% } else { %>

      <!-- 🔒 Not logged in -->
      <a href="/users/login" class="host-btn">
        Become a Host
      </a>

      <a href="/users/login" class="host-btn">
        Log in
      </a>

      <a href="/users/register" class="host-btn">
