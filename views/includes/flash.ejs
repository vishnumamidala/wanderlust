<% if(success && success.length > 0) { %>
  <div class="flash-container">
    <div class="flash-toast flash-success">
      <div class="flash-icon-wrapper">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z" fill="currentColor"/>
        </svg>
      </div>
      <span class="flash-message-text"><%= success %></span>
      <button class="flash-close-btn" onclick="this.closest('.flash-toast').remove()">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12 19 6.41z" fill="currentColor"/>
        </svg>
      </button>
    </div>
  </div>
<% } %>

<% if(error && error.length > 0) { %>
  <div class="flash-container">
    <div class="flash-toast flash-error">
      <div class="flash-icon-wrapper">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" fill="currentColor"/>
        </svg>
      </div>
      <span class="flash-message-text"><%= error %></span>
      <button class="flash-close-btn" onclick="this.closest('.flash-toast').remove()">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12 19 6.41z" fill="currentColor"/>
        </svg>
      </button>
    </div>
  </div>
<% } %>

<style>
/* Modern Toast-style Flash Messages */
.flash-container {
  position: fixed;
  bottom: 24px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 9999;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateX(-50%) translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
}

.flash-toast {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 20px;
  background: white;
  border-radius: 12px;
  box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15), 0 2px 8px rgba(0, 0, 0, 0.1);
  min-width: 320px;
  max-width: 450px;
}

.flash-success {
  border-left: 4px solid #00a680;
}

.flash-error {
  border-left: 4px solid #ff385c;
}

.flash-icon-wrapper {
  width: 24px;
  height: 24px;
  flex-shrink: 0;
}

.flash-success .flash-icon-wrapper {
  color: #00a680;
}

.flash-error .flash-icon-wrapper {
  color: #ff385c;
}

.flash-message-text {
  flex: 1;
  font-size: 15px;
  font-weight: 500;
  color: #222;
  line-height: 1.4;
}

.flash-close-btn {
  width: 24px;
  height: 24px;
  padding: 0;
  border: none;
  background: transparent;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background 0.2s;
  color: #717171;
}

.flash-close-btn:hover {
  background: #f7f7f7;
}

.flash-close-btn svg {
  width: 16px;
  height: 16px;
}

/* Auto-hide animation */
.flash-toast {
  animation: slideUp 0.3s ease-out, fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* Responsive */
@media (max-width: 480px) {
  .flash-container {
    bottom: 16px;
    left: 16px;
    right: 16px;
    transform: none;
  }
  
  .flash-toast {
    min-width: auto;
    width: 100%;
    padding: 12px 16px;
  }
}
</style>

<script>
// Auto-remove flash messages after 4 seconds
document.addEventListener('DOMContentLoaded', function() {
  const flashes = document.querySelectorAll('.flash-toast');
  flashes.forEach(flash => {
    setTimeout(() => {
      flash.style.opacity = '0';
      flash.style.transform = 'translateX(-50%) translateY(10px)';
      flash.style.transition = 'all 0.3s ease';
      setTimeout(() => flash.remove(), 300);
    }, 4000);
  });
});
</script>
